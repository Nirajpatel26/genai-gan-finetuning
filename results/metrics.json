    {
      "id": "exp_02",
      "name": "DCGAN No Stability Techniques",
      "architecture": "DCGAN (Conv layers)",
      "dataset": "CIFAR-10",
      "epochs": 100,
      "batch_size": 64,
      "g_lr": 0.0002,
      "d_lr": 0.0002,
      "label_smoothing": false,
      "final_g_loss": 1.82,
      "final_d_loss": 0.38,
      "issues": ["discriminator_dominance"],
      "visual_quality": "moderate"
    },
    {
      "id": "exp_03",
      "name": "DCGAN + Label Smoothing",
      "architecture": "DCGAN (Conv layers)",
      "dataset": "CIFAR-10",
      "epochs": 200,
      "batch_size": 64,
      "g_lr": 0.0002,
      "d_lr": 0.0002,
      "label_smoothing": 0.9,
      "final_g_loss": 1.45,
      "final_d_loss": 0.55,
      "issues": [],
