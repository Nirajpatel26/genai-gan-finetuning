    },
    {
      "id": "exp_04",
      "name": "DCGAN + Label Smoothing + Asymmetric LR",
      "architecture": "DCGAN (Conv layers)",
      "dataset": "CIFAR-10",
      "epochs": 200,
      "batch_size": 64,
      "g_lr": 0.0002,
      "d_lr": 0.0001,
      "label_smoothing": 0.9,
      "final_g_loss": 1.19,
      "final_d_loss": 0.62,
      "issues": [],
      "visual_quality": "excellent",
      "best_run": true,
      "notes": "Stable training, no mode collapse, diverse high-quality samples"
    }
  ],
  "key_findings": [
    "Label smoothing was the single most impactful stability technique",
    "Asymmetric LR (G > D) prevented discriminator dominance",
    "BatchNorm in both G and D was essential — removing from either caused collapse",
    "Convolutional architecture resolved mode collapse seen in dense GAN",
    "Adam with beta_1=0.5 (vs default 0.9) improved convergence significantly"
  ]
